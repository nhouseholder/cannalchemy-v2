# Supabase — get these from your Supabase project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — get these from Stripe Dashboard → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-price-id

# Supabase service role (for webhook server-side writes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (AI explanations)
VITE_ANTHROPIC_KEY=your-anthropic-key
